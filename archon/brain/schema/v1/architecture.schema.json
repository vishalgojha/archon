{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Architecture",
  "type": "object",
  "additionalProperties": false,
  "required": ["components", "relationships"],
  "properties": {
    "version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time"
    },
    "summary": {
      "type": "string"
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "type"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "type": "string"
          },
          "responsibilities": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": []
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "default": {}
          }
        }
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source", "target", "type"],
        "properties": {
          "source": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string"
          },
          "protocol": {
            "type": "string"
          },
          "metadata": {
            "type": "object",
            "additionalProperties": true,
            "default": {}
          }
        }
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": []
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "default": {}
    }
  }
}
